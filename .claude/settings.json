{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(uv run train.py*)",
      "Bash(uv run prepare.py*)",
      "Bash(uv run bench.py*)",
      "Bash(uv run analysis.py*)",
      "Bash(uv run python tests/*)",
      "Bash(uv sync*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git reset:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git rev-parse:*)",
      "Bash(grep:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(tr:*)",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pgrep:*)",
      "Bash(pkill -f train.py*)",
      "Bash(pkill -f prepare.py*)",
      "Bash(printf:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(uv run python -c:*)",
      "Bash(uv run --script:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c '\nimport sys, json, os\ntry:\n    data = json.load(sys.stdin)\n    fp = data.get(\"tool_input\", {}).get(\"file_path\", \"\")\nexcept Exception:\n    sys.exit(0)\npd = os.environ.get(\"CLAUDE_PROJECT_DIR\", \"\") or os.getcwd()\nif not fp or not pd:\n    sys.exit(0)\nrf = os.path.realpath(fp)\nrd = os.path.realpath(pd)\nif rf == rd or rf.startswith(rd + \"/\"):\n    sys.exit(0)\nprint(\"BLOCKED: file operation outside project: \" + fp, file=sys.stderr)\nsys.exit(2)\n'"
          }
        ]
      }
    ]
  }
}
