{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(uv run train.py*)",
      "Bash(uv run prepare.py*)",
      "Bash(uv run bench.py*)",
      "Bash(uv run analysis.py*)",
      "Bash(uv run python tests/*)",
      "Bash(uv sync*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git reset:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git rev-parse:*)",
      "Bash(grep:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(tr:*)",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pgrep:*)",
      "Bash(pkill -f train.py*)",
      "Bash(pkill -f prepare.py*)",
      "Bash(printf:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(uv run python -c:*)",
      "Bash(uv run --script:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FP=$(cat | sed -n 's/.*\"file_path\" *: *\"\\([^\"]*\\)\".*/\\1/p' | head -1); [ -z \"$FP\" ] && exit 2; RD=$(realpath \"${CLAUDE_PROJECT_DIR:-.}\" 2>/dev/null); RF=$(realpath \"$FP\" 2>/dev/null || echo \"$(realpath \"$(dirname \"$FP\")\" 2>/dev/null || dirname \"$FP\")/$(basename \"$FP\")\"); case \"$RF\" in \"$RD\"/*|\"$RD\") exit 0 ;; *) echo \"BLOCKED: file operation outside project: $FP\" >&2; exit 2 ;; esac"
          }
        ]
      }
    ]
  }
}
